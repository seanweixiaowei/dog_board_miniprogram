<!-- pages/rooms/rooms.wxml -->
<view class="container">
  <view class="section-title">房间管理</view>

  <!-- 操作按钮 -->
  <view class="form-actions" style="margin-bottom: 40rpx;">
    <button class="btn btn-primary" bindtap="showAddRoomModal" wx:if="{{isAdmin}}">+ 添加房间</button>
  </view>

  <!-- 房间列表 -->
  <view wx:if="{{rooms.length === 0}}" class="loading">
    暂无房间数据
  </view>

  <view wx:else class="rooms-grid">
    <view wx:for="{{rooms}}" wx:key="id" class="room-card {{item.status}}">
      <view class="room-number">{{item.number}}</view>
      <view class="room-type">{{roomTypeNames[item.type]}}</view>
      <view class="room-price">{{item.price}}元/天</view>
      <view>狗狗: <text wx:if="{{item.dogCount > 0}}">{{item.dogCount > 1 ? '共' + item.dogCount + '只狗狗' : item.currentDog.name}}</text><text wx:else>无</text></view>
      <view>品种: <text wx:if="{{item.dogCount > 0 && item.currentDog && item.currentDog.breed}}">{{item.currentDog.breed}}</text><text wx:else>无</text></view>
      <view style="margin: 20rpx 0;">
        <view wx:if="{{item.status === 'available'}}" class="status-badge status-available">
          空闲
        </view>
        <view wx:else class="status-badge status-occupied">
          已占用
        </view>
      </view>
      <view class="room-dog">
        {{item.notes || '无备注'}}
      </view>
      <view style="margin-top: 30rpx; display: flex; gap: 20rpx;" wx:if="{{isAdmin}}">
        <button class="btn" style="flex: 1; font-size: 24rpx;" bindtap="editRoom" data-id="{{item.id}}">编辑</button>
        <button class="btn btn-danger" style="flex: 1; font-size: 24rpx;" bindtap="deleteRoom" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 添加/编辑房间模态框 -->
  <view wx:if="{{showModal}}" class="modal-mask" bindtap="closeModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <view style="font-size: 36rpx; font-weight: bold;">{{isEditing ? '编辑房间' : '添加房间'}}</view>
        <button class="btn" style="font-size: 48rpx; background: none; border: none;" bindtap="closeModal">×</button>
      </view>

      <form bindsubmit="saveRoom">
        <input type="hidden" name="roomId" value="{{currentRoom.id}}" />

        <view class="form-group">
          <view class="form-label">房间号</view>
          <input class="form-input" name="roomNumber" value="{{currentRoom.number}}" placeholder="请输入房间号" required />
        </view>

        <view class="form-group">
          <view class="form-label">房间类型</view>
          <picker class="form-input" name="roomType" value="{{roomTypeIndex}}" range="{{roomTypeOptions}}" range-key="label" bindchange="onRoomTypeChange">
            <view wx:if="{{currentRoom.type === 'standard'}}">标准庭院房 (98元/天)</view>
            <view wx:elif="{{currentRoom.type === 'deluxe'}}">豪华庭院房 (128元/天)</view>
            <view wx:elif="{{currentRoom.type === 'vip'}}">贵宾房 (198元/天)</view>
            <view wx:else>请选择房间类型</view>
          </picker>
        </view>

        <!-- 入住狗狗信息 -->
        <view class="form-group">
          <view class="form-label">入住狗狗</view>
          <view wx:if="{{currentRoom.currentDogs && currentRoom.currentDogs.length > 0}}" style="margin-top: 10rpx;">
            <view style="font-size: 28rpx; color: #666; margin-bottom: 10rpx; background: #f5f5f5; padding: 5rpx 10rpx; border-radius: 5rpx;">
              共{{currentRoom.dogCount}}只狗狗
            </view>
            <scroll-view scroll-y style="max-height: 400rpx; padding-right: 10rpx;">
              <view wx:for="{{currentRoom.currentDogs}}" wx:key="id" class="card" style="margin-bottom: 20rpx; padding: 20rpx; border: 2rpx solid #ddd; background: #fff; border-radius: 10rpx;">
                <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 10rpx;">{{item.name}}</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">品种: {{item.breed || '-'}}</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">性别: {{item.gender === 'male' ? '公' : item.gender === 'female' ? '母' : '未知'}}</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">年龄: {{item.age || '-'}}</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">主人: {{item.owner}} ({{item.phone}})</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">咬人: {{item.bitesPeople ? '是' : '否'}} | 咬狗: {{item.bitesDogs ? '是' : '否'}}</view>
                <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">疫苗: {{item.vaccinated ? '已接种' : '未接种'}} | 绝育: {{item.neutered ? '已绝育' : '未绝育'}} | 驱虫: {{item.dewormed ? '已驱虫' : '未驱虫'}}</view>
                <view style="margin-top: 10rpx;">
                  <view wx:if="{{item.status === '在店'}}" class="status-badge status-occupied">
                    {{item.status}}
                  </view>
                  <view wx:else class="status-badge status-available">
                    {{item.status}}
                  </view>
                </view>
                <view wx:if="{{item.illnesses}}" style="margin-top: 10rpx; padding-top: 10rpx; border-top: 2rpx solid #eee; color: #666; font-size: 26rpx;">
                  <text style="font-weight: bold;">疾病历史:</text> {{item.illnesses}}
                </view>
                <view wx:if="{{item.specialNotes}}" style="margin-top: 10rpx; padding-top: 10rpx; border-top: 2rpx solid #eee; color: #666; font-size: 26rpx;">
                  <text style="font-weight: bold;">特殊要求:</text> {{item.specialNotes}}
                </view>
              </view>
            </scroll-view>
          </view>
          <view wx:elif="{{currentRoom.currentDog}}" class="card" style="margin-top: 10rpx; padding: 20rpx; border: 2rpx solid #ddd; background: #fff;">
            <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 10rpx;">{{currentRoom.currentDog.name}}</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">品种: {{currentRoom.currentDog.breed || '-'}}</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">性别: {{currentRoom.currentDog.gender === 'male' ? '公' : currentRoom.currentDog.gender === 'female' ? '母' : '未知'}}</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">年龄: {{currentRoom.currentDog.age || '-'}}</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">主人: {{currentRoom.currentDog.owner}} ({{currentRoom.currentDog.phone}})</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">咬人: {{currentRoom.currentDog.bitesPeople ? '是' : '否'}} | 咬狗: {{currentRoom.currentDog.bitesDogs ? '是' : '否'}}</view>
            <view style="color: #666; font-size: 28rpx; margin-bottom: 5rpx;">疫苗: {{currentRoom.currentDog.vaccinated ? '已接种' : '未接种'}} | 绝育: {{currentRoom.currentDog.neutered ? '已绝育' : '未绝育'}} | 驱虫: {{currentRoom.currentDog.dewormed ? '已驱虫' : '未驱虫'}}</view>
            <view style="margin-top: 10rpx;">
              <view wx:if="{{currentRoom.currentDog.status === '在店'}}" class="status-badge status-occupied">
                {{currentRoom.currentDog.status}}
              </view>
              <view wx:else class="status-badge status-available">
                {{currentRoom.currentDog.status}}
              </view>
            </view>
            <view wx:if="{{currentRoom.currentDog.illnesses}}" style="margin-top: 10rpx; padding-top: 10rpx; border-top: 2rpx solid #eee; color: #666; font-size: 26rpx;">
              <text style="font-weight: bold;">疾病历史:</text> {{currentRoom.currentDog.illnesses}}
            </view>
            <view wx:if="{{currentRoom.currentDog.specialNotes}}" style="margin-top: 10rpx; padding-top: 10rpx; border-top: 2rpx solid #eee; color: #666; font-size: 26rpx;">
              <text style="font-weight: bold;">特殊要求:</text> {{currentRoom.currentDog.specialNotes}}
            </view>
          </view>
          <view wx:else style="padding: 40rpx 20rpx; text-align: center; color: #666; font-size: 28rpx; border: 2rpx solid #ddd; margin-top: 10rpx;">
            无狗狗入住
          </view>
        </view>

        <view class="form-group">
          <view class="form-label">备注</view>
          <textarea class="form-input" name="roomNotes" value="{{currentRoom.notes}}" placeholder="请输入备注" rows="3" />
        </view>

        <view class="form-actions">
          <button form-type="submit" class="btn btn-primary" wx:if="{{isAdmin}}">保存</button>
          <button type="button" class="btn" bindtap="closeModal">取消</button>
        </view>
      </form>
    </view>
  </view>
</view>