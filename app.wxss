/* app.wxss - 全局样式 */
page {
  font-family: 'Microsoft YaHei', sans-serif;
  background-color: #f5f5f5;
  color: #333;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border: 1rpx solid #ddd;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.05);
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 4rpx solid #000;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: "│";
  margin-right: 10rpx;
}

/* 按钮样式 */
.btn {
  padding: 20rpx 40rpx;
  border: 2rpx solid #000;
  background: #fff;
  font-size: 28rpx;
  border-radius: 0;
  text-align: center;
}

.btn-primary {
  background: #000;
  color: #fff;
}

.btn-danger {
  border-color: #000;
  color: #000;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #ccc;
  font-size: 28rpx;
  border-radius: 0;
}

.form-input:focus {
  border-color: #000;
}

/* 状态标签 */
.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-available {
  background-color: #f5f5f5;
  color: #333;
  border: 2rpx solid #ddd;
}

.status-occupied {
  background-color: #333;
  color: #fff;
  border: 2rpx solid #000;
}

.status-pending {
  background-color: #fff3cd;
  color: #856404;
  border: 2rpx solid #ffeaa7;
}

/* 表格样式 */
.table-container {
  overflow-x: auto;
  margin-top: 30rpx;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 28rpx;
}

.data-table th,
.data-table td {
  padding: 24rpx 30rpx;
  text-align: left;
  border-bottom: 2rpx solid #ddd;
}

.data-table th {
  background-color: #f8f8f8;
  font-weight: 600;
  border-bottom: 4rpx solid #000;
}

/* 房间卡片 */
.rooms-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
  justify-content: flex-start;
}

.room-card {
  flex: none;
  width: calc(50% - 20rpx);
  margin: 10rpx;
  border: 2rpx solid #ddd;
  padding: 30rpx;
  background: #fff;
  box-sizing: border-box;
  min-width: 0;
}

.room-card.occupied {
  border-left: 8rpx solid #333;
}

.room-card.available {
  border-left: 8rpx solid #ddd;
}

.room-number {
  font-size: 48rpx;
  font-weight: 300;
  margin-bottom: 20rpx;
}

.room-type {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.room-price {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
}

.room-dog {
  font-size: 28rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #eee;
  margin-top: 20rpx;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
  justify-content: flex-start;
}

.stat-card {
  flex: none;
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background: #fff;
  padding: 30rpx;
  border: 2rpx solid #ddd;
  text-align: center;
  box-sizing: border-box;
  min-width: 0;
}

.stat-number {
  font-size: 72rpx;
  font-weight: 300;
  margin: 20rpx 0;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
}

/* 加载动画 */
.loading {
  text-align: center;
  padding: 80rpx;
  color: #666;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  padding: 60rpx;
  width: 80%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 4rpx solid #000;
}

/* 搜索框 */
.search-box {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #ccc;
  font-size: 28rpx;
  height: auto;
  min-height: 0;
  display: flex;
  align-items: center;
}

.search-box .btn {
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

/* 时间线 */
.timeline {
  position: relative;
  padding-left: 60rpx;
  margin: 40rpx 0;
}

.timeline-item {
  position: relative;
  margin-bottom: 40rpx;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid #eee;
}

.timeline-item::before {
  content: "";
  position: absolute;
  left: -60rpx;
  top: 10rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #000;
}

/* 简笔画图标 */
.dog-icon {
  font-size: 48rpx;
  text-align: center;
  margin: 20rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 48rpx;
  height: 48rpx;
}

/* 移动端适配 */
@media (max-width: 750rpx) {
  .data-table th,
  .data-table td {
    padding: 16rpx 20rpx;
    font-size: 24rpx;
  }
}