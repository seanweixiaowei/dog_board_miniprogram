/* pages/settings/settings.wxss */
.container {
  padding: 40rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #333;
  border-left: 10rpx solid #333;
  padding-left: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 25rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.form-input:focus {
  border-color: #333;
  outline: none;
}

.form-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn {
  background-color: #f8f8f8;
  border: 2rpx solid #ddd;
  color: #333;
  padding: 25rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary {
  background-color: #333;
  border-color: #333;
  color: #fff;
}

.btn-danger {
  background-color: #ff4444;
  border-color: #ff4444;
  color: #fff;
}

.btn:disabled {
  background-color: #f0f0f0;
  border-color: #e0e0e0;
  color: #999;
  opacity: 0.6;
}

/* 状态样式 */
.status-success {
  background-color: #d4edda;
  border-color: #c3e6cb;
  color: #155724;
}

.status-error {
  background-color: #f8d7da;
  border-color: #f5c6cb;
  color: #721c24;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .container {
    padding: 20rpx;
  }

  .card {
    padding: 30rpx;
  }

  .btn {
    padding: 20rpx;
  }
}