/* pages/login/login.wxss */
/* 现代黑白风格登录页面 */

page {
  background-color: #ffffff;
  color: #000000;
}

/* 重置按钮默认样式 */
button {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  font-family: inherit;
  font-size: inherit;
  color: inherit;
  line-height: inherit;
}

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 140rpx 40rpx 60rpx;
  background: #ffffff;
  position: relative;
  overflow: hidden;
}

/* 背景装饰元素 */
.login-container::before {
  content: "";
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  z-index: 0;
}

/* 品牌头部（现在在表单内部） */
.login-header {
  text-align: center;
  margin-bottom: 50rpx;
  position: relative;
}

/* 左上角Logo容器 */
.logo-top-left {
  position: absolute;
  top: 40rpx;
  left: 40rpx;
  width: 120rpx;
  height: 120rpx;
  z-index: 2;
}



.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 15rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  position: relative;
}

.app-title::after {
  content: "";
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #000000;
  border-radius: 2rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #666666;
  letter-spacing: 1rpx;
  font-weight: 300;
  margin-top: 30rpx;
}

/* 登录表单容器 */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background: #f9f9f9;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  padding: 60rpx 40rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(20rpx);
  position: relative;
  z-index: 1;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.1);
}


/* 错误信息 */
.error-message {
  background: rgba(255, 87, 87, 0.1);
  border: 2rpx solid rgba(255, 87, 87, 0.3);
  color: #ff5757;
  padding: 25rpx 30rpx;
  border-radius: 10rpx;
  margin-bottom: 40rpx;
  font-size: 26rpx;
  text-align: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 表单组 */
.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 30rpx;
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.2);
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #000000;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.form-input:focus {
  outline: none;
  border-color: #000000;
  background: #ffffff;
  box-shadow: 0 0 20rpx rgba(0,0,0,0.1);
}

.form-input::placeholder {
  color: rgba(0, 0, 0, 0.3);
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  padding: 30rpx;
  background: #000000;
  border: none;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-top: 20rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.login-btn::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.login-btn:active::before {
  width: 300rpx;
  height: 300rpx;
}

.login-btn:disabled {
  background: rgba(0, 0, 0, 0.3);
  color: rgba(255, 255, 255, 0.5);
  cursor: not-allowed;
}

/* 快速登录区域 */
.quick-login-section {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.1);
}

.quick-login-title {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.quick-login-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.quick-btn {
  flex: 1;
  padding: 25rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.3);
  background: transparent;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #000000;
  transition: all 0.3s ease;
  text-align: center;
}

.quick-btn:active {
  transform: translateY(2rpx);
}

.admin-btn {
  border-color: #000000;
  background: rgba(0, 0, 0, 0.1);
}

.admin-btn:active {
  background: rgba(0, 0, 0, 0.2);
}

.viewer-btn {
  border-color: #666666;
  background: rgba(102, 102, 102, 0.05);
}

.viewer-btn:active {
  background: rgba(102, 102, 102, 0.1);
}

.quick-login-hint {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  text-align: center;
}

.quick-login-hint text {
  flex: 1;
  padding: 0 10rpx;
}

/* 使用说明 */
.instructions {
  margin-top: 60rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.1);
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.6);
}

.instruction-title {
  font-size: 26rpx;
  color: #000000;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.instruction-item {
  margin-bottom: 12rpx;
  line-height: 1.6;
  position: relative;
  padding-left: 30rpx;
}

.instruction-item::before {
  content: "•";
  position: absolute;
  left: 10rpx;
  color: #000000;
}

/* 响应式设计 */
@media (max-width: 600rpx) {
  .login-container {
    padding: 40rpx 30rpx;
  }

  .logo-top-left {
    width: 100rpx;
    height: 100rpx;
    top: 30rpx;
    left: 30rpx;
  }



  .app-title {
    font-size: 40rpx;
  }

  .app-subtitle {
    font-size: 24rpx;
  }

  .login-form {
    padding: 50rpx 30rpx;
  }


  .quick-login-buttons {
    flex-direction: column;
  }

  .quick-btn {
    padding: 30rpx;
  }
}

/* 加载动画 */
.login-btn.loading::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 隐藏数字输入框的spinner */
.form-input[type="number"]::-webkit-inner-spin-button,
.form-input[type="number"]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

.form-input[type="number"] {
  -moz-appearance: textfield;
}

/* 左上角Logo图片 */
.logo-top-image {
  width: 100%;
  height: 100%;
}

@keyframes spin {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}